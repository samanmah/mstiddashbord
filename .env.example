# ==========================================================================
# نمونه فایل متغیرهای محیطی — این فایل نباید حاوی مقدار محرمانه واقعی باشد.
# برای اجرای محلی، از این فایل یک کپی به نام .env بسازید و مقادیر را پر کنید.
# ==========================================================================

# --- محیط ---
NODE_ENV=development
TZ=Asia/Tehran

# --- دیتابیس PostgreSQL ---
POSTGRES_USER=ppm_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ppm_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# در Docker مقدار HOST برابر نام سرویس (postgres) است.
DATABASE_URL=postgresql://ppm_user:change_me_strong_password@localhost:5432/ppm_db?schema=public

# --- API ---
API_PORT=4000
# چند Origin با کاما جدا می‌شوند
CORS_ORIGINS=http://localhost:3000
# طول عمر توکن‌ها
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- Secrets (حداقل ۳۲ کاراکتر تصادفی؛ در Production حتماً تغییر دهید) ---
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_chars_0000
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_chars_00
COOKIE_SECRET=dev_cookie_secret_change_me_min_32_chars_00

# --- Cookie ---
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- امنیت ورود ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_MAX=10

# --- آپلود ---
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=20971520

# --- کاربران Seed (فقط برای توسعه/راه‌اندازی اولیه) ---
SEED_EDITOR_USERNAME=editor
SEED_EDITOR_PASSWORD=Editor@Passw0rd!
SEED_VIEWER_USERNAME=viewer
SEED_VIEWER_PASSWORD=Viewer@Passw0rd!

# --- Frontend ---
WEB_PORT=3000
# آدرس API از دید مرورگر (پشت Nginx معمولاً /api)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
# آدرس API از دید سرور Next.js (SSR) — در Docker: http://api:4000/api/v1
API_INTERNAL_BASE_URL=http://localhost:4000/api/v1
APP_VERSION=1.0.0

# --- Deployment / Domain (Production) ---
APP_DOMAIN=example.com
# Origin کامل برنامه (برای CORS در Production)
APP_ORIGIN=https://example.com
# Image های ساخته‌شده روی GHCR (توسط GitHub Actions پر می‌شوند)
API_IMAGE=ghcr.io/samanmah/mstiddashbord-api:latest
WEB_IMAGE=ghcr.io/samanmah/mstiddashbord-web:latest
# اجرای Seed هنگام Startup کانتینر API (فقط بار اول true شود)
RUN_SEED_ON_START=false
# --- Backup ---
BACKUP_DIR=/var/backups/ppm
BACKUP_RETENTION_DAYS=14
