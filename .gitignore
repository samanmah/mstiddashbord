# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Prisma
apps/api/prisma/*.db
apps/api/prisma/migrations/**/migration_lock.toml.bak

# Environment / secrets
.env
.env.local
.env.*.local
.env.staging
.env.production
*.env
!.env.example
!.env.staging.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/
apps/web/playwright/.auth/
apps/web/e2e/.auth/

# Uploads (user files must not be committed)
uploads/
apps/api/uploads/

# Project control — confidential raw source files must NEVER be committed
references/project-control/private/
references/project-control/*.xlsx
references/project-control/*.xlsm
references/project-control/*.mpp
references/project-control/*.mpx
references/project-control/*.xml
# Local, non-committed analysis scratch space
references/project-control/_scratch/

# Database backups
backups/
*.dump
*.sql.gz

# Artifacts (generated screenshots kept out of VCS except placeholder)
artifacts/*
!artifacts/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
