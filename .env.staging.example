# ==========================================================================
# نمونه متغیرهای Staging — Secret واقعی قرار ندهید.
# کپی: cp .env.staging.example .env.staging
# فایل .env.staging در .gitignore است و هرگز Commit نشود.
# ==========================================================================

COMPOSE_PROJECT_NAME=ppm_project_control_staging

# --- محیط ---
NODE_ENV=development
TZ=Asia/Tehran
LOG_LEVEL=debug

# --- PostgreSQL مستقل Staging ---
POSTGRES_USER=ppm_staging_user
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password_min_24
POSTGRES_DB=ppm_project_control_staging
DATABASE_URL=postgresql://ppm_staging_user:CHANGE_ME_staging_db_password_min_24@postgres:5432/ppm_project_control_staging?schema=public

# --- Secrets (Placeholder — حداقل ۳۲ کاراکتر تصادفی تولید کنید) ---
JWT_ACCESS_SECRET=CHANGE_ME_staging_access_secret_min_32_chars_xx
JWT_REFRESH_SECRET=CHANGE_ME_staging_refresh_secret_min_32_chars_x
COOKIE_SECRET=CHANGE_ME_staging_cookie_secret_min_32_chars_xx

# --- Cookie / Origin (Staging داخلی HTTP) ---
APP_ORIGIN=http://127.0.0.1:18080
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Seed ---
RUN_SEED_ON_START=true
SEED_EDITOR_USERNAME=editor
SEED_EDITOR_PASSWORD=CHANGE_ME_Editor_Staging_Pass!
SEED_VIEWER_USERNAME=viewer
SEED_VIEWER_PASSWORD=CHANGE_ME_Viewer_Staging_Pass!

# --- Upload / Import ---
UPLOAD_MAX_SIZE=20971520
IMPORT_TEMP_DIR=/tmp/ppm-import
MPXJ_ADAPTER_PATH=
JAVA_HOME=

# --- Imageهای نسخه‌دار (Commit-based — نه latest) ---
# پس از build-images.sh، تگ را با SHA کوتاه Commit جاری جایگزین کنید.
API_IMAGE=ghcr.io/samanmah/mstiddashbord-api:project-control-a75655f
WEB_IMAGE=ghcr.io/samanmah/mstiddashbord-web:project-control-a75655f
APP_VERSION=a75655f869972b709032c7d54e49c62e07aa8821
GIT_SHA=a75655f869972b709032c7d54e49c62e07aa8821
