// Prisma schema — سامانه پایش پیشرفت پروژه‌های استراتژیک
// Datasource: PostgreSQL. تمام شناسه‌های اصلی از نوع UUID هستند.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MANAGER_VIEWER
  PROJECT_EDITOR
}

enum ActivityStatus {
  GOOD
  AVERAGE
  WEAK
  UNKNOWN
}

enum Probability {
  LOW
  MEDIUM
  HIGH
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum DecisionStatus {
  NEW
  IN_PROGRESS
  WAITING_FOR_REPORT
  DONE
  OTHER
}

enum ImportStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  username           String
  normalizedUsername String    @unique
  fullName           String
  passwordHash       String
  role               UserRole  @default(MANAGER_VIEWER)
  isActive           Boolean   @default(true)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  passwordChangedAt  DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  refreshTokens RefreshToken[]
  imports       ImportLog[]    @relation("ImportedBy")
  auditLogs     AuditLog[]     @relation("AuditUser")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?   @db.Uuid
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Project {
  id                String   @id @default(uuid()) @db.Uuid
  titleFa           String
  titleEn           String?
  projectCode       String?
  projectManager    String
  projectType       String
  budgetBillionRial Float    @default(0)
  description       String   @default("")
  startDate         DateTime @db.Date
  plannedEndDate    DateTime @db.Date
  reportDate        DateTime @db.Date
  logoUrl           String?
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  version           Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // --- Advanced Project Control (additive, feature-flagged) ---
  projectControlEnabled Boolean   @default(false)
  activeControlPlanId   String?   @db.Uuid
  controlStatusDate     DateTime? @db.Date
  controlCurrency       String?
  controlVersion        Int       @default(1)

  indicators      ProjectIndicator[]
  monthlyProgress MonthlyProgress[]
  activities      Activity[]
  risks           Risk[]
  decisions       Decision[]
  imports         ImportLog[]
  auditLogs       AuditLog[]

  controlPlans      ProjectControlPlan[]
  wbsNodes          WbsNode[]
  taskDependencies  TaskDependency[]
  progressUpdates   ProgressUpdate[]
  baselines         ProjectBaseline[]
  importBatches     ImportBatch[]
  scheduleSnapshots ProjectScheduleSnapshot[]

  @@index([isActive])
  @@index([displayOrder])
  @@index([projectControlEnabled])
  @@map("projects")
}

model ProjectIndicator {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  title        String
  plannedValue Float    @default(0)
  actualValue  Float    @default(0)
  unit         String?
  isPrimary    Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, isPrimary])
  @@map("project_indicators")
}

model MonthlyProgress {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @db.Uuid
  jalaliYear     Int
  jalaliMonth    Int
  monthLabel     String
  sortOrder      Int      @default(0)
  date           DateTime @db.Date
  plannedPercent Float    @default(0)
  actualPercent  Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, jalaliYear, jalaliMonth])
  @@index([projectId])
  @@index([projectId, sortOrder])
  @@map("monthly_progress")
}

model Activity {
  id             String          @id @default(uuid()) @db.Uuid
  projectId      String          @db.Uuid
  rowNumber      Int
  title          String
  weightPercent  Float           @default(0)
  startDate      DateTime        @db.Date
  endDate        DateTime        @db.Date
  plannedPercent Float           @default(0)
  actualPercent  Float           @default(0)
  statusOverride ActivityStatus?
  notes          String?
  displayOrder   Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([deletedAt])
  @@map("activities")
}

model Risk {
  id               String      @id @default(uuid()) @db.Uuid
  projectId        String      @db.Uuid
  rowNumber        Int
  title            String
  probability      Probability @default(MEDIUM)
  riskLevel        RiskLevel   @default(MEDIUM)
  mitigationAction String      @default("")
  owner            String      @default("")
  dueDate          DateTime?   @db.Date
  status           String?
  displayOrder     Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  // --- Optional links to project-control hierarchy (additive) ---
  phaseNodeId String? @db.Uuid
  wbsNodeId   String? @db.Uuid

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseNode WbsNode? @relation("RiskPhaseNode", fields: [phaseNodeId], references: [id], onDelete: SetNull)
  wbsNode   WbsNode? @relation("RiskWbsNode", fields: [wbsNodeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([deletedAt])
  @@index([phaseNodeId])
  @@index([wbsNodeId])
  @@map("risks")
}

model Decision {
  id           String         @id @default(uuid()) @db.Uuid
  projectId    String         @db.Uuid
  rowNumber    Int
  subject      String?
  description  String?
  owner        String?
  dueDate      DateTime?      @db.Date
  status       DecisionStatus @default(NEW)
  displayOrder Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  // --- Optional links to project-control hierarchy (additive) ---
  phaseNodeId String? @db.Uuid
  wbsNodeId   String? @db.Uuid

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseNode WbsNode? @relation("DecisionPhaseNode", fields: [phaseNodeId], references: [id], onDelete: SetNull)
  wbsNode   WbsNode? @relation("DecisionWbsNode", fields: [wbsNodeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([deletedAt])
  @@index([phaseNodeId])
  @@index([wbsNodeId])
  @@map("decisions")
}

model ImportLog {
  id               String       @id @default(uuid()) @db.Uuid
  projectId        String?      @db.Uuid
  originalFilename String
  storedFilename   String?
  fileHash         String
  status           ImportStatus @default(PENDING)
  importedByUserId String?      @db.Uuid
  totalRows        Int          @default(0)
  successRows      Int          @default(0)
  failedRows       Int          @default(0)
  validationErrors Json?
  createdAt        DateTime     @default(now())
  completedAt      DateTime?

  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  importedBy User?    @relation("ImportedBy", fields: [importedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([fileHash])
  @@index([createdAt])
  @@map("import_logs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  projectId  String?  @db.Uuid
  entityType String
  entityId   String?
  action     String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user    User?    @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// Advanced Project Control — WBS / Gantt / Executive Monitoring (additive)
// همهٔ مدل‌ها و enumهای زیر جدید و Backward-Compatible هستند.
// ============================================================================

enum WbsNodeType {
  PROJECT
  PHASE
  BREAK1
  WORK_PACKAGE
  SUMMARY_TASK
  TASK
  MILESTONE
  DELIVERABLE
}

enum WeightSource {
  EXPLICIT
  MPP_CUSTOM_FIELD
  COST_DERIVED
  DURATION_DERIVED
  EQUAL_DERIVED
  NONE
}

enum DependencyType {
  FS
  SS
  FF
  SF
}

enum DependencySource {
  EXCEL
  MPP
  MANUAL
}

enum AssignmentRole {
  OWNER
  RESPONSIBLE
  ACCOUNTABLE
  CONSULTED
  INFORMED
  REVIEWER
  APPROVER
}

enum ControlNodeStatus {
  NOT_STARTED
  ON_TRACK
  AT_RISK
  DELAYED
  BLOCKED
  COMPLETED
  CANCELLED
  UNKNOWN
}

enum ControlPeriodUnit {
  DAY
  WEEK
  MONTH
  QUARTER
}

enum ControlImportSourceType {
  EXCEL
  MPP
}

enum ControlImportStatus {
  UPLOADED
  PARSING
  PARSED
  MAPPING
  VALIDATED
  DRY_RUN
  COMMITTING
  COMPLETED
  FAILED
  CANCELLED
}

enum ImportMatchStatus {
  UNMATCHED
  AUTO_MATCHED
  MANUAL_MATCHED
  AMBIGUOUS
  CONFLICT
  IGNORED
}

enum PeriodValueType {
  PLANNED
  ACTUAL
  UNKNOWN
}

/// نوع محور دوره — برای فایل واقعی STYLE_BASED فقط ORDINAL اثبات شده است.
enum PeriodAxisType {
  ORDINAL
  CALENDAR_DAY
  CALENDAR_WEEK
  CALENDAR_MONTH
}

enum GanttSpanType {
  PLANNED
  ACTUAL
  PROGRESS
  DELAY
  OTHER
}

enum GanttDerivationMethod {
  EXCEL_CONDITIONAL_FORMATTING
  EXPLICIT_PERIOD_VALUE
  MANUAL
}

model ProjectControlPlan {
  id                  String            @id @default(uuid()) @db.Uuid
  projectId           String            @db.Uuid
  title               String
  description         String?
  statusDate          DateTime          @db.Date
  scheduleStart       DateTime?         @db.Date
  scheduleFinish      DateTime?         @db.Date
  baselineId          String?           @db.Uuid
  periodUnit          ControlPeriodUnit @default(MONTH)
  periodCount         Int?
  totalDurationDays   Int?
  totalDurationMonths Int?
  timezone            String            @default("Asia/Tehran")
  currency            String            @default("IRR")
  isActive            Boolean           @default(false)
  version             Int               @default(1)
  createdByUserId     String?           @db.Uuid
  updatedByUserId     String?           @db.Uuid
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  project           Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsNodes          WbsNode[]
  dependencies      TaskDependency[]
  baselines         ProjectBaseline[]
  importBatches     ImportBatch[]
  scheduleSnapshots ProjectScheduleSnapshot[]
  periodColumns     ControlPeriodColumn[]
  periodSnapshots   NodePeriodSnapshot[]
  ganttSpans        NodeGanttSpan[]

  @@index([projectId])
  @@index([projectId, isActive])
  @@index([statusDate])
  @@map("project_control_plans")
}

/// تعریف ستون/دوره محور گانت (معادل ControlPlanPeriod).
/// برای فایل STYLE_BASED: axisType=ORDINAL و calendarStart/End=null.
model ControlPeriodColumn {
  id            String          @id @default(uuid()) @db.Uuid
  projectId     String          @db.Uuid
  controlPlanId String          @db.Uuid
  columnIndex   Int
  columnLetter  String
  periodIndex   Int
  periodLabel   String
  periodGroup   String?
  valueType     PeriodValueType @default(UNKNOWN)
  axisType      PeriodAxisType  @default(ORDINAL)
  calendarStart DateTime?       @db.Date
  calendarEnd   DateTime?       @db.Date
  reportingDate DateTime?       @db.Date
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  controlPlan ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)

  @@unique([controlPlanId, columnIndex])
  @@unique([controlPlanId, periodIndex])
  @@index([projectId])
  @@index([controlPlanId])
  @@map("control_period_columns")
}

/// بازهٔ نمایشی گانت مشتق از قواعد Conditional Formatting (نه سلول‌به‌سلول).
model NodeGanttSpan {
  id                     String                 @id @default(uuid()) @db.Uuid
  projectId              String                 @db.Uuid
  controlPlanId          String                 @db.Uuid
  nodeId                 String                 @db.Uuid
  spanType               GanttSpanType
  startPeriodIndex       Int
  endPeriodIndex         Int
  progressEndPeriodIndex Int?
  sourceRow              Int?
  derivationMethod       GanttDerivationMethod  @default(EXCEL_CONDITIONAL_FORMATTING)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  controlPlan ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)
  node        WbsNode            @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([controlPlanId, nodeId, spanType])
  @@index([projectId])
  @@index([controlPlanId])
  @@index([nodeId])
  @@map("node_gantt_spans")
}

/// مقدار دوره‌ای Persist‌شده برای یک نود WBS.
model NodePeriodSnapshot {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @db.Uuid
  controlPlanId   String          @db.Uuid
  nodeId          String          @db.Uuid
  importBatchId   String?         @db.Uuid
  periodIndex     Int
  periodLabel     String?
  reportingDate   DateTime?       @db.Date
  valueType       PeriodValueType
  plannedValue    Float?
  actualValue     Float?
  normalizedValue Float?
  sourceRow       Int?
  sourceColumn    Int?
  zeroIsExplicit  Boolean         @default(false)
  rawValue        String?
  formula         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  controlPlan ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)
  node        WbsNode            @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([controlPlanId, nodeId, periodIndex, valueType])
  @@index([projectId])
  @@index([controlPlanId])
  @@index([nodeId])
  @@index([reportingDate])
  @@index([importBatchId])
  @@map("node_period_snapshots")
}

model WbsNode {
  id            String  @id @default(uuid()) @db.Uuid
  projectId     String  @db.Uuid
  controlPlanId String  @db.Uuid
  parentId      String? @db.Uuid

  code            String?
  externalUid     String?
  sourceRow       Int?
  sourceFileType  String?
  sourceFileHash  String?
  sourceRawTitle  String?
  title           String
  normalizedTitle String
  description     String?

  depth            Int
  outlineNumber    String?
  materializedPath String
  nodeType         WbsNodeType @default(TASK)
  isSummary        Boolean     @default(false)
  isMilestone      Boolean     @default(false)
  isActive         Boolean     @default(true)
  sortOrder        Int         @default(0)

  plannedStart   DateTime? @db.Date
  plannedFinish  DateTime? @db.Date
  actualStart    DateTime? @db.Date
  actualFinish   DateTime? @db.Date
  forecastFinish DateTime? @db.Date
  baselineStart  DateTime? @db.Date
  baselineFinish DateTime? @db.Date
  deadline       DateTime? @db.Date

  plannedDurationMinutes   Int?
  actualDurationMinutes    Int?
  remainingDurationMinutes Int?

  periodPlanStart      Int?
  periodPlanDuration   Int?
  periodActualStart    Int?
  periodActualDuration Int?

  percentComplete         Float?
  physicalProgress        Float?
  plannedProgressOverride Float?
  financialProgress       Float?

  weight       Float?
  weightSource WeightSource @default(NONE)

  budgetAmount         Decimal? @db.Decimal(20, 2)
  mppCost              Decimal? @db.Decimal(20, 2)
  baselineCost         Decimal? @db.Decimal(20, 2)
  actualCost           Decimal? @db.Decimal(20, 2)
  workMinutes          Int?
  actualWorkMinutes    Int?
  remainingWorkMinutes Int?

  ownerText        String?
  definitionOfDone String?
  notes            String?
  statusOverride   ControlNodeStatus?
  constraintType   String?
  constraintDate   DateTime?          @db.Date
  calendarName     String?

  version   Int       @default(1)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlPlan ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)
  parent      WbsNode?           @relation("WbsNodeHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    WbsNode[]          @relation("WbsNodeHierarchy")

  assignments            NodeAssignment[]
  progressUpdates        ProgressUpdate[]
  baselineSnapshots      BaselineNodeSnapshot[]
  periodSnapshots        NodePeriodSnapshot[]
  ganttSpans             NodeGanttSpan[]
  predecessorLinks       TaskDependency[]       @relation("DependencyPredecessor")
  successorLinks         TaskDependency[]       @relation("DependencySuccessor")
  importSourceRecords    ImportSourceRecord[]
  linkedRisksAsPhase     Risk[]                 @relation("RiskPhaseNode")
  linkedRisksAsWbs       Risk[]                 @relation("RiskWbsNode")
  linkedDecisionsAsPhase Decision[]             @relation("DecisionPhaseNode")
  linkedDecisionsAsWbs   Decision[]             @relation("DecisionWbsNode")

  @@index([projectId])
  @@index([controlPlanId])
  @@index([parentId])
  @@index([controlPlanId, parentId])
  @@index([controlPlanId, sortOrder])
  @@index([materializedPath])
  @@index([nodeType])
  @@index([externalUid])
  @@index([deletedAt])
  @@map("wbs_nodes")
}

model TaskDependency {
  id                String           @id @default(uuid()) @db.Uuid
  projectId         String           @db.Uuid
  controlPlanId     String           @db.Uuid
  predecessorNodeId String           @db.Uuid
  successorNodeId   String           @db.Uuid
  type              DependencyType   @default(FS)
  lagMinutes        Int              @default(0)
  source            DependencySource @default(MANUAL)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlPlan     ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)
  predecessorNode WbsNode            @relation("DependencyPredecessor", fields: [predecessorNodeId], references: [id], onDelete: Cascade)
  successorNode   WbsNode            @relation("DependencySuccessor", fields: [successorNodeId], references: [id], onDelete: Cascade)

  @@unique([predecessorNodeId, successorNodeId, type])
  @@index([projectId])
  @@index([controlPlanId])
  @@index([predecessorNodeId])
  @@index([successorNodeId])
  @@map("task_dependencies")
}

model NodeAssignment {
  id                   String         @id @default(uuid()) @db.Uuid
  nodeId               String         @db.Uuid
  userId               String?        @db.Uuid
  externalResourceName String?
  role                 AssignmentRole @default(OWNER)
  allocationPercent    Float?
  createdAt            DateTime       @default(now())

  node WbsNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([userId])
  @@map("node_assignments")
}

model ProgressUpdate {
  id                       String            @id @default(uuid()) @db.Uuid
  projectId                String            @db.Uuid
  nodeId                   String            @db.Uuid
  reportingDate            DateTime          @db.Date
  actualPercent            Float
  physicalProgress         Float?
  financialProgress        Float?
  actualCost               Decimal?          @db.Decimal(20, 2)
  remainingDurationMinutes Int?
  forecastFinish           DateTime?         @db.Date
  status                   ControlNodeStatus @default(UNKNOWN)
  comment                  String?
  evidenceUrl              String?
  createdByUserId          String?           @db.Uuid
  createdAt                DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  node    WbsNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([nodeId])
  @@index([nodeId, reportingDate])
  @@index([reportingDate])
  @@map("progress_updates")
}

model ProjectBaseline {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  controlPlanId   String   @db.Uuid
  title           String
  baselineNumber  Int
  statusDate      DateTime @db.Date
  isActive        Boolean  @default(false)
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())

  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlPlan ProjectControlPlan     @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)
  snapshots   BaselineNodeSnapshot[]

  @@unique([controlPlanId, baselineNumber])
  @@index([projectId])
  @@index([controlPlanId])
  @@index([controlPlanId, isActive])
  @@map("project_baselines")
}

model BaselineNodeSnapshot {
  id                        String    @id @default(uuid()) @db.Uuid
  baselineId                String    @db.Uuid
  nodeId                    String    @db.Uuid
  plannedStart              DateTime? @db.Date
  plannedFinish             DateTime? @db.Date
  plannedDurationMinutes    Int?
  budgetAmount              Decimal?  @db.Decimal(20, 2)
  weight                    Float?
  percentCompleteAtBaseline Float?
  createdAt                 DateTime  @default(now())

  baseline ProjectBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  node     WbsNode         @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([baselineId, nodeId])
  @@index([baselineId])
  @@index([nodeId])
  @@map("baseline_node_snapshots")
}

model ImportBatch {
  id               String                  @id @default(uuid()) @db.Uuid
  projectId        String                  @db.Uuid
  controlPlanId    String?                 @db.Uuid
  sourceType       ControlImportSourceType
  originalFilename String
  fileHash         String
  parserVersion    String
  status           ControlImportStatus     @default(UPLOADED)
  totalRows        Int                     @default(0)
  importedRows     Int                     @default(0)
  warningRows      Int                     @default(0)
  failedRows       Int                     @default(0)
  validationReport Json?
  mappingReport    Json?
  importedByUserId String?                 @db.Uuid
  createdAt        DateTime                @default(now())
  completedAt      DateTime?

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlPlan ProjectControlPlan?  @relation(fields: [controlPlanId], references: [id], onDelete: SetNull)
  records     ImportSourceRecord[]

  @@index([projectId])
  @@index([controlPlanId])
  @@index([fileHash])
  @@index([status])
  @@index([createdAt])
  @@map("import_batches")
}

model ImportSourceRecord {
  id             String            @id @default(uuid()) @db.Uuid
  importBatchId  String            @db.Uuid
  sourceRow      Int
  sourceUid      String?
  rawData        Json
  normalizedData Json
  matchedNodeId  String?           @db.Uuid
  matchStatus    ImportMatchStatus @default(UNMATCHED)
  createdAt      DateTime          @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  matchedNode WbsNode?    @relation(fields: [matchedNodeId], references: [id], onDelete: SetNull)

  @@index([importBatchId])
  @@index([matchedNodeId])
  @@index([matchStatus])
  @@map("import_source_records")
}

model ProjectScheduleSnapshot {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  controlPlanId    String   @db.Uuid
  reportingDate    DateTime @db.Date
  plannedPercent   Float
  actualPercent    Float
  physicalPercent  Float
  financialPercent Float?
  plannedValue     Decimal? @db.Decimal(20, 2)
  earnedValue      Decimal? @db.Decimal(20, 2)
  actualCost       Decimal? @db.Decimal(20, 2)
  spi              Float?
  cpi              Float?
  createdAt        DateTime @default(now())

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlPlan ProjectControlPlan @relation(fields: [controlPlanId], references: [id], onDelete: Cascade)

  @@unique([controlPlanId, reportingDate])
  @@index([projectId])
  @@index([controlPlanId])
  @@index([reportingDate])
  @@map("project_schedule_snapshots")
}
