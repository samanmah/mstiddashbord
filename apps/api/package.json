{
  "name": "@ppm/api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS API — سامانه پایش پیشرفت پروژه‌های استراتژیک",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:unit": "jest --config jest.config.js --testPathPattern=\\.spec\\.ts$",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@ppm/contracts": "workspace:*",
    "@nestjs/common": "10.4.7",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.7",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.7",
    "@nestjs/swagger": "8.0.7",
    "@nestjs/terminus": "10.2.3",
    "@nestjs/throttler": "6.2.1",
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "exceljs": "4.4.0",
    "helmet": "8.0.0",
    "multer": "1.4.5-lts.1",
    "nestjs-pino": "4.1.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino-http": "10.3.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "11.0.3"
  },
  "devDependencies": {
    "@ppm/eslint-config": "workspace:*",
    "@ppm/tsconfig": "workspace:*",
    "@nestjs/cli": "10.4.7",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.7",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/multer": "1.4.12",
    "@types/node": "22.9.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "eslint": "9.13.0",
    "jest": "29.7.0",
    "pino-pretty": "13.0.0",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.3"
  }
}
